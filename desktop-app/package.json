{
  "name": "flowx-desktop",
  "productName": "KC Auto Tool",
  "version": "0.1.0",
  "private": true,
  "description": "KC Auto Tool desktop orchestrator by KC Dev",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "smoke:characters": "node scripts/phase2-character-smoke.mjs",
    "smoke:reconnect": "node scripts/phase1-reconnect-smoke.mjs",
    "smoke:timeline": "node scripts/phase3-timeline-smoke.mjs",
    "smoke:scenes": "node scripts/phase3-timeline-smoke.mjs",
    "smoke:phase5": "node scripts/phase3-timeline-smoke.mjs",
    "smoke:workers": "node scripts/phase1-smoke.mjs",
    "test": "tsx --test src/shared/character.test.ts src/shared/timeline.test.ts src/shared/scene-job.test.ts src/main/character-store.test.ts src/main/project-database.test.ts src/main/production-queue.test.ts src/main/visual-style-store.test.ts src/main/timeline-session-store.test.ts src/main/worker-server.test.ts src/main/content-chat-batching.test.ts src/main/content-flow-settings.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "lowdb": "7.0.1",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.0",
    "electron-vite": "5.0.0",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vite": "7.3.6"
  }
}
